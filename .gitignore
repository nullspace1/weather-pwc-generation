# ============================================================================
# Python & Backend Defaults
# ============================================================================
# Byte-compiled / optimized / DLL files
__pycache__/
*.py[cod]
*$py.class

# Virtual Environments
.venv/
venv/
ENV/
env/

# Distribution / packaging
bin/
build/
develop-eggs/
dist/
downloads/
eggs/
.eggs/
lib/
lib64/
parts/
sdist/
var/
wheels/
share/python-wheels/
*.egg-info/
.installed.cfg
*.egg
MANIFEST

# Inline documentation / C extensions
modules/
*.so

# Test / coverage
.toml
.cache
.pytest_cache/
.coverage
.coverage.*
.htmlcov/
nosetests.xml
coverage.xml
htmlcov/
.mypy_cache/
.ruff_cache/

# Databases (SQLite default)
*.db
*.sqlite3

# ============================================================================
# React & Frontend Defaults (Node / Bundlers)
# ============================================================================
# Dependency directories
node_modules/
jspm_packages/

# Production build outputs
/dist
/build
/out

# Build logs and diagnostics
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*
lerna-debug.log*

# Next.js / Gatsby caches
.next/
.gatsby/
.turbo/

# Vite / Nuxt build caches
.vite/
.nuxt/

# TypeScript declaration cache
*.tsbuildinfo

# ============================================================================
# Environment Variables & Sensitive Secrets (CRITICAL)
# ============================================================================
.env
.env.local
.env.development.local
.env.test.local
.env.production.local
*.env

# ============================================================================
# Operating System & IDE specific files
# ============================================================================
# macOS
.DS_Store
.AppleDouble
.LSOverride

# Windows
Thumbs.db
desktop.ini

# VS Code
.vscode/*
!.vscode/extensions.json
!.vscode/settings.json
!.vscode/launch.json

# JetBrains (PyCharm / WebStorm)
.idea/

# Local history (e.g. Editors)
.history/

pytest.ini
*.cpython-312.pyc